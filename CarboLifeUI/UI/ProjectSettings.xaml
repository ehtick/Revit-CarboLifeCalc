<UserControl x:Class="CarboLifeUI.UI.ProjectSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CarboLifeUI.UI"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1300"
             IsVisibleChanged="UserControl_IsVisibleChanged">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MyStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="White">
        <StackPanel Margin="8">

            <Label Style="{StaticResource baseStyleTitle}" Content="Project Settings" Margin="0,0,0,6"/>

            <!-- ═══ Basic Settings ═══ -->
            <GroupBox Header="Basic Settings" Style="{StaticResource formTitleStyle}" Margin="0,0,0,8">
                <Grid Margin="6,4,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Project Name -->
                    <Label Grid.Row="0" Grid.Column="0" Content="Project Name:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <TextBox Name="txt_ProjectName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                             Height="28" Margin="0,4,0,4" Style="{StaticResource flatTextBox}"
                             TextChanged="txt_ProjectName_TextChanged"/>

                    <!-- Project Number -->
                    <Label Grid.Row="1" Grid.Column="0" Content="Project Number:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <TextBox Name="txt_Number" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4"
                             Height="28" Margin="0,4,0,4" Style="{StaticResource flatTextBox}"
                             TextChanged="txt_Number_TextChanged"/>

                    <!-- Project Category -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Project Category:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <ComboBox Name="cbb_BuildingType" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                              Height="28" Margin="0,4,0,4" VerticalAlignment="Top"
                              Style="{StaticResource ComboBoxFlatStyle}"
                              DropDownClosed="cbb_BuildingType_DropDownClosed"/>

                    <!-- Description -->
                    <Label Grid.Row="3" Grid.Column="0" Content="Project Description:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Top"/>
                    <TextBox Name="txt_Desctiption" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                             Height="64" Margin="0,4,4,4" Style="{StaticResource flatTextBox}"
                             VerticalContentAlignment="Top" AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                             TextChanged="txt_Desctiption_TextChanged"/>
                    <Button Name="btn_EditDescription" Grid.Row="3" Grid.Column="4"
                            Content="Edit..." Width="52" Height="28" Margin="0,4,0,4"
                            VerticalAlignment="Top" Style="{StaticResource ButtonStyle}"
                            Click="btn_EditDescription_Click"/>

                    <!-- Total Area + New Area -->
                    <Label Grid.Row="4" Grid.Column="0" Content="Total Area (GIA):"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <Grid Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_Area" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_Area_TextChanged"/>
                        <Label Grid.Column="1" Content="m²" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="4,0,0,0"/>
                        <Label Grid.Column="2" Content="" Width="16"/>
                        <TextBox Name="txt_AreaNew" Grid.Column="3" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_AreaNew_TextChanged"/>
                        <Label Grid.Column="4" Content="m²" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="4,0,0,0"/>
                        <CheckBox Name="chx_IsTotalBuilding" Grid.Column="5" Grid.ColumnSpan="2"
                                  Margin="8,0,0,0" VerticalAlignment="Center"
                                  FontSize="12" FontFamily="Segoe UI" IsChecked="True"
                                  Visibility="Hidden"
                                  Checked="chx_IsTotalBuilding_Checked"
                                  Unchecked="chx_IsTotalBuilding_Checked">Total = New Area</CheckBox>
                    </Grid>

                    <!-- Currency -->
                    <Label Grid.Row="5" Grid.Column="0" Content="Currency:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <ComboBox Name="cbb_Currency" Grid.Row="5" Grid.Column="1"
                              Height="28" Margin="0,4,0,4" MaxWidth="200" HorizontalAlignment="Left"
                              Style="{StaticResource ComboBoxFlatStyle}"
                              DropDownClosed="cbb_Currency_DropDownClosed"/>

                    <!-- Design Life -->
                    <Label Grid.Row="6" Grid.Column="0" Content="Design life:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <Grid Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_DesignLife" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_DesignLife_TextChanged"/>
                        <Label Grid.Column="1" Content="Year" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="6,0,0,0"/>
                        <Label Grid.Column="2" VerticalAlignment="Center"
                               Style="{StaticResource formHelpText}"
                               Content="The expected time this building will exist"/>
                    </Grid>

                    <!-- Social Carbon Cost -->
                    <Label Grid.Row="7" Grid.Column="0" Content="Social Carbon Cost:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <Grid Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_SocialCost" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_SocialCost_TextChanged"/>
                        <Label Grid.Column="1" Content="$/£/€ per tCO₂e" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="6,0,0,0"/>
                        <Label Grid.Column="2" VerticalAlignment="Center"
                               Style="{StaticResource formHelpText}"
                               Content="SCC is estimated between £140 or $180 per tCO₂e"/>
                    </Grid>

                    <!-- Uncertainty Factor -->
                    <Label Grid.Row="8" Grid.Column="0" Content="Uncertainty Factor:"
                           Style="{StaticResource formTextStyle}" Margin="0,4,8,0" VerticalAlignment="Center"/>
                    <Grid Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_Uncert" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_Uncert_TextChanged"/>
                        <Label Grid.Column="1" Content="%" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="4,0,0,0"/>
                        <Label Grid.Column="2" VerticalAlignment="Center"
                               Style="{StaticResource formHelpText}"
                               Content="RICS guideline: 15% early stage · 10% design stage · 1% construction"/>
                    </Grid>

                </Grid>
            </GroupBox>

            <!-- ═══ Global Values ═══ -->
            <GroupBox Header="Global Values:" Style="{StaticResource formTitleStyle}" Margin="0,0,0,8">
                <Grid Margin="6,4,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="175"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- A0 -->
                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                           Content="A0 — Pre Construction"
                           Style="{StaticResource formTitleStyle}" Margin="0,4,0,0"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="CO₂e:"
                           Style="{StaticResource formTextStyle}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_A0Value" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_A0Value_TextChanged"/>
                        <Label Grid.Column="1" Content="tCO₂e" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="6,0,0,0"/>
                    </Grid>
                    <TextBox Name="txt_A0Total" Grid.Row="1" Grid.Column="2" Height="28"
                             Margin="0,0,0,4" Style="{StaticResource textboxReadOnlyStyle}" IsEnabled="False"/>
                    <Label Grid.Row="1" Grid.Column="3" Content="tCO₂e"
                           Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                           Padding="6,0,0,0" Margin="0,0,0,4"/>
                    <Label Grid.Row="1" Grid.Column="4" Style="{StaticResource formHelpText}"
                           VerticalAlignment="Center" Margin="6,0,0,4"
                           Content="Carbon cost of any work undertaken prior to the start of construction"/>

                    <!-- A5 -->
                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                           Content="A5 — Global Construction"
                           Style="{StaticResource formTitleStyle}" Margin="0,8,0,0"/>
                    <Label Grid.Row="3" Grid.Column="0" Content="Project value:"
                           Style="{StaticResource formTextStyle}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Hidden fields preserved for code-behind compatibility -->
                        <TextBox Name="txt_Value" Grid.Column="0" Height="28" Visibility="Hidden"
                                 Style="{StaticResource flatTextBox}"/>
                        <Label Name="lbl_Currency" Grid.Column="1" Content="$/£/€ x"
                               Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                               Padding="6,0,0,0" Visibility="Hidden"/>
                        <TextBox Name="txt_ValueA5Fact" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_ValueA5Fact_TextChanged"/>
                        <Label Name="lbl_Currencyunit" Grid.Column="1" Content="kgCO₂e/m²"
                               Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                               Padding="6,0,0,0"/>
                    </Grid>
                    <TextBox Name="txt_A5Total" Grid.Row="3" Grid.Column="2" Height="28"
                             Margin="0,0,0,4" Style="{StaticResource textboxReadOnlyStyle}" IsEnabled="False"/>
                    <Label Grid.Row="3" Grid.Column="3" Content="tCO₂e"
                           Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                           Padding="6,0,0,0" Margin="0,0,0,4"/>
                    <Label Grid.Row="3" Grid.Column="4" Style="{StaticResource formHelpText}"
                           VerticalAlignment="Center" Margin="6,0,0,4"
                           Content="RICS guideline: 40 kgCO₂e/m² (total) or 20 kgCO₂e/m² (structure)"/>

                </Grid>
            </GroupBox>

            <!-- ═══ Energy + Demolition (separate groupbox for clarity) ═══ -->
            <GroupBox Header="Operational &amp; End of Life:" Style="{StaticResource formTitleStyle}" Margin="0,0,0,8">
                <Grid Margin="6,4,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="175"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- B6/B7 Energy -->
                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
                           Content="B6 / B7 &amp; D2 — Energy"
                           Style="{StaticResource formTitleStyle}" Margin="0,4,0,0"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="Energy &amp; water total:"
                           Style="{StaticResource formTextStyle}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_EnergyPerYear" Grid.Column="0" Height="28"
                                 IsReadOnly="True" Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_EnergyPerYear_TextChanged"/>
                        <Button Name="btn_CalcEnergy" Grid.Column="1" Content="Calc..."
                                Height="28" Width="52" Margin="6,0,0,0"
                                Style="{StaticResource ButtonStyle}"
                                Click="btn_CalcEnergy_Click"/>
                    </Grid>
                    <TextBox Name="txt_EnergyTotal" Grid.Row="1" Grid.Column="2" Height="28"
                             Margin="0,0,0,4" Style="{StaticResource textboxReadOnlyStyle}" IsEnabled="False"/>
                    <Label Grid.Row="1" Grid.Column="3" Content="tCO₂e"
                           Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                           Padding="6,0,0,0" Margin="0,0,0,4"/>
                    <Label Grid.Row="1" Grid.Column="4" Style="{StaticResource formHelpText}"
                           VerticalAlignment="Center" Margin="6,0,0,4"
                           Content="Annual energy consumption of the entire building"/>

                    <!-- C1 Demolition -->
                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                           Content="C1 — Demolition"
                           Style="{StaticResource formTitleStyle}" Margin="0,8,0,0"/>
                    <Label Grid.Row="3" Grid.Column="0" Content="Total demolished area:"
                           Style="{StaticResource formTextStyle}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_DemoArea" Grid.Column="0" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_DemoArea_TextChanged"/>
                        <Label Name="lbl_perM2" Grid.Column="1" Content="m²"
                               VerticalAlignment="Center" Style="{StaticResource formTextStyle}"
                               Padding="4,0,0,0"/>
                        <Label Grid.Column="2" Content="×" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                        <TextBox Name="txt_DemoC1Fact" Grid.Column="3" Height="28"
                                 Style="{StaticResource flatTextBox}"
                                 TextChanged="txt_DemoC1Fact_TextChanged"/>
                        <Label Grid.Column="4" Content="kgCO₂/m²" VerticalAlignment="Center"
                               Style="{StaticResource formTextStyle}" Padding="6,0,0,0"/>
                    </Grid>
                    <TextBox Name="txt_C1Total" Grid.Row="3" Grid.Column="2" Height="28"
                             Margin="0,0,0,4" Style="{StaticResource textboxReadOnlyStyle}" IsEnabled="False"/>
                    <Label Grid.Row="3" Grid.Column="3" Content="tCO₂e"
                           Style="{StaticResource formTextStyle}" VerticalAlignment="Center"
                           Padding="6,0,0,0" Margin="0,0,0,4"/>
                    <Label Grid.Row="3" Grid.Column="4" Style="{StaticResource formHelpText}"
                           VerticalAlignment="Center" Margin="6,0,0,4"
                           Content="RICS guideline: 35 kgCO₂ per m² of demolished area"/>

                </Grid>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>