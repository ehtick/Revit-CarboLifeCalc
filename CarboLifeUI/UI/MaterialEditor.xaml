<Window x:Class="CarboLifeUI.UI.MaterialEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Material Editor"
        Height="760" Width="950"
        MinHeight="600" MinWidth="850"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        Background="#F0F0F0"
        Icon="pack://application:,,,/CarboLifeUI;component/Resources/ico_clcwindow.ico">

    <Window.Resources>
        <ResourceDictionary Source="MyStyles.xaml"/>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Title -->
        <Label DockPanel.Dock="Top" Style="{StaticResource baseStyleTitle}"
               Content="Material Editor" Margin="0,0,0,8"/>

        <!-- Footer -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center" Orientation="Horizontal">
                <Button Name="btn_New" Content="New" Width="60" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="Btn_New_Click"/>
                <Button Name="btn_Delete" Content="Delete" Width="60" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="Btn_Delete_Click"/>
                <Button Name="btn_Duplicate" Content="Duplicate" Width="72" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="btn_Duplicate_Click"/>
                <Button Name="btn_ToTemplate" Content="To Template" Width="90" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="btn_TemplateSync_Click"/>
                <Button Name="btn_Sync" Content="Sync..." Width="60" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="btn_Sync_Click"/>
                <Button Name="btn_Import" Width="70" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="btn_Import_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/CarboLifeUI;component/Resources/ui_table16.png"
                               Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CSV..." VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- Hidden -->
                <Button Name="btn_CopyProperties" Content="Copy From" Width="72" Height="26"
                        Style="{StaticResource ButtonStyle}" Visibility="Hidden"/>
                <Button Name="btn_Sync_Copy" Content="Developer" Width="72" Height="26"
                        Style="{StaticResource ButtonStyle}" Click="btn_Sync_Copy_Click"
                        Visibility="Hidden"/>
            </WrapPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Name="btn_Apply" Content="Apply Values" Width="90" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="Btn_Apply_Click"/>
                <Button Name="btn_Accept" Content="Accept" Width="80" Height="26" Margin="0,0,4,0"
                        Style="{StaticResource ButtonStyle}" Click="Btn_Accept_Click"/>
                <Button Name="btn_Cancel" Content="Cancel" Width="80" Height="26"
                        Style="{StaticResource ButtonStyle}" Click="Btn_Cancel_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Main content: two columns, fills remaining space -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" MinWidth="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.5*" MinWidth="450"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: search + list ── -->
            <DockPanel Grid.Column="0">
                <Label DockPanel.Dock="Top" Content="Material Category:"
                       Style="{StaticResource formTextStyle}" Margin="0,0,0,2"/>
                <ComboBox Name="cbb_Categories" DockPanel.Dock="Top" Height="28" Margin="0,0,0,8"
                          Style="{StaticResource ComboBoxFlatStyleLight}"
                          DropDownClosed="Cbb_Categories_DropDownClosed"/>

                <Label DockPanel.Dock="Top" Content="Search:"
                       Style="{StaticResource formTextStyle}" Margin="0,0,0,2"/>
                <TextBox Name="txt_Search" DockPanel.Dock="Top" Height="28" Margin="0,0,0,8"
                         Style="{StaticResource textboxStyle}"
                         TextChanged="Txt_Search_TextChanged"/>

                <!-- ListView takes all remaining height -->
                <ListView Name="liv_materialList"
                          SelectionChanged="Liv_materialList_SelectionChanged"
                          FontFamily="Segoe UI" FontSize="11" Background="White">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="Category" Width="90"
                                            DisplayMemberBinding="{Binding Category}"/>
                            <GridViewColumn Header="Name" Width="150"
                                            DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="ECI" Width="60"
                                            DisplayMemberBinding="{Binding Path=ECI, StringFormat=N3}"
                                            TextBlock.TextAlignment="Right"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <!-- ── RIGHT: properties, scrollable ── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Label Style="{StaticResource baseStyleTitle}" Content="Properties" Margin="0,0,0,6"/>

                    <!-- General -->
                    <GroupBox Header="General" Style="{StaticResource baseStyleBold}" Margin="0,0,0,8">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Name -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Name:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_Name" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                     Height="26" Margin="2,2,2,4"
                                     Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_Name_TextChanged"/>

                            <!-- Description -->
                            <Label Grid.Row="1" Grid.Column="0" Content="Description:"
                                   VerticalAlignment="Top" Margin="0,6,0,0"
                                   Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_Description" Grid.Row="1" Grid.Column="1"
                                     Height="52" Margin="2,2,2,4"
                                     AcceptsReturn="True" SpellCheck.IsEnabled="True"
                                     VerticalContentAlignment="Top"
                                     Style="{StaticResource flatTextBox}"/>
                            <Button Name="btn_EditDescription" Grid.Row="1" Grid.Column="2"
                                    Content="Edit..." Width="52" Height="26" Margin="2,2,0,4"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource ButtonStyle}"
                                    Click="btn_EditDescription_Click"/>

                            <!-- Category -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Category:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <ComboBox Name="cbb_Category" Grid.Row="2" Grid.Column="1"
                                      Height="26" Margin="2,2,2,4" VerticalAlignment="Center"
                                      Style="{StaticResource ComboBoxFlatStyle}"
                                      DropDownClosed="cbb_Category_DropDownClosed"/>
                            <Button Name="btn_AddCategory" Grid.Row="2" Grid.Column="2"
                                    Content="Add..." Width="52" Height="26" Margin="2,2,0,4"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ButtonStyle}"
                                    Click="btn_AddCategory_Click"/>

                            <!-- Density -->
                            <Label Grid.Row="3" Grid.Column="0" Content="Density:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <DockPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="2,2,2,4">
                                <Label DockPanel.Dock="Right" Content="kg/m³"
                                       VerticalAlignment="Center" Style="{StaticResource formTextStyle}"
                                       Padding="4,0,0,0"/>
                                <TextBox Name="txt_Density" Height="26"
                                         Style="{StaticResource flatTextBox}"
                                         TextChanged="txt_Density_TextChanged"/>
                            </DockPanel>

                            <!-- EPD Link -->
                            <Label Grid.Row="4" Grid.Column="0" Content="EPD Link:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_EPDLink" Grid.Row="4" Grid.Column="1"
                                     Height="26" Margin="2,2,2,4" VerticalAlignment="Center"
                                     Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_EPDLink_TextChanged"/>
                            <Button Name="btn_OpenLink" Grid.Row="4" Grid.Column="2"
                                    Content="Open..." Width="52" Height="26" Margin="2,2,0,4"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ButtonStyle}"
                                    Click="btn_OpenLink_Click"/>

                            <!-- Waste + Grade -->
                            <Label Grid.Row="5" Grid.Column="0" Content="Default Waste:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <Grid Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="2,2,2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Name="txt_Waste" Grid.Column="0" Height="26"
                                         Style="{StaticResource flatTextBox}"
                                         TextChanged="txt_Waste_TextChanged"/>
                                <Label Grid.Column="1" Content="%" VerticalAlignment="Center"
                                       Style="{StaticResource formTextStyle}" Padding="4,0,0,0"/>
                                <Label Grid.Column="2" Content="Grade:" VerticalAlignment="Center"
                                       Style="{StaticResource formTextStyle}" Padding="0"/>
                                <TextBox Name="txt_Grade" Grid.Column="3" Height="26"
                                         Style="{StaticResource flatTextBox}"
                                         TextChanged="txt_Grade_TextChanged"/>
                            </Grid>
                        </Grid>
                    </GroupBox>

                    <!-- Material Data -->
                    <GroupBox Header="Material Data" Style="{StaticResource baseStyleBold}" Margin="0,0,0,8">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Column headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Description"
                                       HorizontalAlignment="Center" FontSize="9"
                                       Foreground="Gray" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Value |kgCO₂e/kg|"
                                       HorizontalAlignment="Center" FontSize="9"
                                       Foreground="Gray" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="OVR"
                                       HorizontalAlignment="Center" FontSize="9"
                                       Foreground="Gray" VerticalAlignment="Center"/>

                            <!-- A1-A3 -->
                            <Label Grid.Row="1" Grid.Column="0" Content="Production [A1-A3]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_A1_A3_Setting" Grid.Row="1" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_A1_A3" Grid.Row="1" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_A1_A3_TextChanged"/>
                            <CheckBox Name="chx_A1_A3_Manual" Grid.Row="1" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_A1_A3_Manual_Click"/>
                            <Button Name="btn_A1_A3" Grid.Row="1" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_A1_A3_Click"/>

                            <!-- A4 -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Transport [A4]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_A4_Setting" Grid.Row="2" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_A4" Grid.Row="2" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_A4_TextChanged"/>
                            <CheckBox Name="chx_A4_Manual" Grid.Row="2" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_A4_Manual_Click"/>
                            <Button Name="btn_A4" Grid.Row="2" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_A4_Click"/>

                            <!-- A5 -->
                            <Label Grid.Row="3" Grid.Column="0" Content="Construction [A5]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_A5_Setting" Grid.Row="3" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_A5" Grid.Row="3" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_A5_TextChanged"/>
                            <CheckBox Name="chx_A5_Manual" Grid.Row="3" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_A5_Manual_Click"/>
                            <Button Name="btn_A5" Grid.Row="3" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_A5_Click"/>

                            <!-- B1-B7 -->
                            <Label Grid.Row="4" Grid.Column="0" Content="In Use [B1-B7]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_B1_B5_Setting" Grid.Row="4" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_B1_B5" Grid.Row="4" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_B1_B5_TextChanged"/>
                            <Button Name="btn_B1_B5" Grid.Row="4" Grid.Column="4"
                                    Content="?" Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_B1_B5_Click"/>

                            <!-- C1-C4 -->
                            <Label Grid.Row="5" Grid.Column="0" Content="End of Life [C1-C4]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_C1_C4_Setting" Grid.Row="5" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_C1_C4" Grid.Row="5" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_C1_C4_TextChanged"/>
                            <CheckBox Name="chx_C1_C4_Manual" Grid.Row="5" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_C1_C4_Manual_Click"/>
                            <Button Name="btn_C1_C4" Grid.Row="5" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_C1_C4_Click"/>

                            <!-- D -->
                            <Label Grid.Row="6" Grid.Column="0" Content="Out of Scope [D]:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_D_Setting" Grid.Row="6" Grid.Column="1"
                                     Margin="2,3" IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_D" Grid.Row="6" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_D_TextChanged"
                                     Text="{Binding Text, Delay=1000}"/>
                            <CheckBox Name="chx_D_Manual" Grid.Row="6" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_D_Manual_Click"/>
                            <Button Name="btn_D" Grid.Row="6" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="Btn_D_Click"/>

                            <!-- Sequestration -->
                            <Label Grid.Row="7" Grid.Column="0" Content="Sequestration:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                            <TextBox Name="txt_Seq_Setting" Grid.Row="7" Grid.Column="1"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"/>
                            <TextBox Name="txt_Seq" Grid.Row="7" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_Seq_TextChanged"
                                     Text="{Binding Text, Delay=1000}"/>
                            <CheckBox Name="chx_Seq_Manual" Grid.Row="7" Grid.Column="3"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Click="chx_Seq_Manual_Click"/>
                            <Button Name="btn_Seq" Grid.Row="7" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="btn_Seq_Click"/>

                            <!-- Additional -->
                            <Label Grid.Row="8" Grid.Column="0" Content="Additional:"
                                   VerticalAlignment="Center" Style="{StaticResource formTextStyle}"
                                   MouseDown="Label_MouseDown"/>
                            <TextBox Name="txt_Mix_Setting" Grid.Row="8" Grid.Column="1"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_Mix_Setting_TextChanged"/>
                            <TextBox Name="txt_Mix" Grid.Row="8" Grid.Column="2"
                                     Margin="2,3" Style="{StaticResource flatTextBox}"
                                     TextChanged="txt_Mix_TextChanged"
                                     Text="{Binding Text, Delay=1000}"/>
                            <Button Name="btn_Mix" Grid.Row="8" Grid.Column="4"
                                    Content="Edit..." Margin="2,3" Style="{StaticResource ButtonStyle}"
                                    Click="btn_Mix_Click"/>

                            <!-- Total -->
                            <Border Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                                    Background="White" BorderBrush="Black" BorderThickness="1"
                                    Margin="0,8,0,0" Padding="6,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Total kgCO₂e per kg:"
                                           VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBox Name="txt_ECI" Grid.Column="1" Height="26" Margin="2"
                                             IsReadOnly="True" Style="{StaticResource flatTextBox}"/>
                                    <Button Name="btn_FromEPD" Grid.Column="2" Content="From EPD..."
                                            Width="90" Height="26" Margin="6,2,0,2"
                                            Style="{StaticResource ButtonStyle}"
                                            Click="btn_FromEPD_Click"/>
                                </Grid>
                            </Border>

                            <!-- Hidden -->
                            <CheckBox x:Name="chx_Total_Manual" Grid.Row="9" Grid.Column="3"
                                      IsEnabled="False" Visibility="Hidden"/>
                            <Label Name="Calc" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                                   Style="{StaticResource formTextStyle}" Visibility="Hidden">[CALC]</Label>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>