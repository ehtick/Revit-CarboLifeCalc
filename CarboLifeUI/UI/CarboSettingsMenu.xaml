<Window x:Class="CarboLifeUI.UI.CarboSettingsMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        Title="Carbo Life Calculator Settings"
        Width="700" Height="650" 
        MinWidth="700" MinHeight="600" 
        Background="WhiteSmoke" 
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded" 
        Icon="pack://application:,,,/CarboLifeUI;component/Resources/ico_clcwindow.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MyStyles.xaml"/>
                <ResourceDictionary Source="MyDataGrid.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Style="{StaticResource baseStyleTitle}" Content="General Settings" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="File Locations &amp; Defaults" Style="{StaticResource bigStyle}" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Templates Path:" Grid.Row="0" VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                <TextBox Name="txt_Path" Grid.Row="0" Grid.Column="1" Margin="2" Height="26" IsEnabled="False" Style="{StaticResource flatTextBox}"/>
                <Button Name="btn_Browse" Content="..." Grid.Row="0" Grid.Column="2" Margin="2" Width="25" Height="25" Style="{StaticResource ButtonStyle}" Click="btn_Browse_Click"/>

                <Label Content="Material Mapping:" Grid.Row="1" VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                <TextBox Name="txt_Mapping" Grid.Row="1" Grid.Column="1" Margin="2" Height="26" IsEnabled="False" Style="{StaticResource flatTextBox}"/>
                <Button Name="btn_BrowseMap" Content="..." Grid.Row="1" Grid.Column="2" Margin="2" Width="25" Height="25" Style="{StaticResource ButtonStyle}" Click="btn_BrowseMap_Click"/>

                <Label Content="Default Design Life:" Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                <TextBox Name="txt_DesignLife" Grid.Row="2" Grid.Column="1" Margin="2" Width="100" HorizontalAlignment="Left" Height="26" Style="{StaticResource flatTextBox}"/>

                <Label Content="Pop-up Removal Key:" Grid.Row="3" VerticalAlignment="Center" Style="{StaticResource formTextStyle}"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <TextBox Name="txt_SecretMessage" Width="150" Height="26" Margin="2" Style="{StaticResource flatTextBox}"/>
                    <Button Name="btn_Check" Content="Check Code" Width="90" Height="26" Margin="5,0" Style="{StaticResource ButtonStyle}" Click="btn_Check_Click"/>
                    <Button Name="btn_Coffee" Content="Get Code" Width="90" Height="26" Style="{StaticResource ButtonStyle}" Click="btn_Coffee_Click"/>
                </StackPanel>

                <CheckBox Name="chx_Experimental" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0" Content="Load Carbo Circle At Startup (Restart of Revit Required)" FontSize="13"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Summary Display Options" Style="{StaticResource bigStyle}">
            <StackPanel Margin="15">
                <Label Content="Include the following comparisons in summary reports:" Margin="0,0,0,10" Style="{StaticResource bigStyle}" FontSize="14"/>

                <WrapPanel>
                    <StackPanel Width="250">
                        <CheckBox Name="chx_Cars" Content="Cars Equivalent" Margin="0,5" FontSize="14"/>
                        <CheckBox Name="chx_Trees" Content="Trees Sequestration" Margin="0,5" FontSize="14"/>
                        <CheckBox Name="chx_Plane" Content="Plane Trips" Margin="0,5" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Width="250">
                        <CheckBox Name="chx_SCC" Content="Social Carbon Cost" Margin="0,5" FontSize="14"/>
                        <CheckBox Name="chx_Deaths" Content="Statistical 'Deaths' Cost" Margin="0,5" FontSize="14"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Name="btn_Ok" Content="Accept" Width="100" Height="30" Style="{StaticResource ButtonStyle}" Click="btn_Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>