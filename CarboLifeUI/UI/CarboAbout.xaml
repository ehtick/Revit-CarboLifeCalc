<Window x:Class="CarboLifeUI.UI.CarboAbout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:CarboLifeUI.UI"
        mc:Ignorable="d" 
        Title="About Carbo Life Calculator"
        Width="750" Height="460" 
        MinWidth="750" MinHeight="460" 
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded" 
        Icon="pack://application:,,,/CarboLifeUI;component/Resources/ico_clcwindow.ico">

    <Window.Resources>
        <ResourceDictionary Source="MyStyles.xaml" />
    </Window.Resources>

    <Grid Background="#F4F4F4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#DCDCDC" BorderThickness="0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <Border CornerRadius="4" Background="White" Padding="8" BorderBrush="#EEEEEE" BorderThickness="1" Margin="0,10,0,15">
                        <Image Source="pack://siteoforigin:,,,/Resources/Logo128.jpg" Width="100" Height="100" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Name="lbl_Version" Text="Build: V 1.2.5" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>

                <Button Name="btn_Accept" Grid.Row="2" 
                        Content="Ok, Thanks" 
                        Height="32" Width="140"
                        Style="{StaticResource ButtonStyle}" 
                        Click="Btn_Accept_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="35,30,35,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Carbo Life Calculator" FontSize="26" FontWeight="ExtraLight" Foreground="#B21616" FontFamily="Segoe UI Light"/>
                <TextBlock Text="Embodied Carbon Calculator to EN 15978:2011" FontSize="13" Foreground="#555555" Margin="2,4,0,0"/>
                <Separator Margin="0,15,0,10" Background="#E0E0E0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="RESOURCES &amp; DATA" FontSize="10" FontWeight="Bold" Foreground="#999999" Margin="0,0,0,12"/>

                    <StackPanel Margin="5,0,0,20">
                        <TextBlock Margin="0,3" FontSize="12">ICE Data: <Hyperlink NavigateUri="https://circularecology.com" RequestNavigate="Hyperlink_RequestNavigate">circularecology.com</Hyperlink></TextBlock>
                        <TextBlock Margin="0,3" FontSize="12">WRAP NW Tool: <Hyperlink NavigateUri="https://wrap.org.uk/..." RequestNavigate="Hyperlink_RequestNavigate">wrap.org.uk</Hyperlink></TextBlock>
                        <TextBlock Margin="0,3" FontSize="12">RICS: <Hyperlink NavigateUri="https://www.rics.org/..." RequestNavigate="Hyperlink_RequestNavigate">Whole life carbon assessment</Hyperlink></TextBlock>
                        <TextBlock Margin="0,3" FontSize="12">IStructE: <Hyperlink NavigateUri="https://www.istructe.org/..." RequestNavigate="Hyperlink_RequestNavigate">How to calculate embodied carbon</Hyperlink></TextBlock>
                    </StackPanel>

                    <TextBlock Text="SUPPORT &amp; PROJECT" FontSize="10" FontWeight="Bold" Foreground="#999999" Margin="0,0,0,12"/>

                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Margin="0,3" FontSize="12">GitHub: <Hyperlink NavigateUri="https://github.com/DavidVeld/CarboLifeCalc" RequestNavigate="Hyperlink_RequestNavigate">Documentation &amp; Source</Hyperlink></TextBlock>
                        <TextBlock Margin="0,3" FontSize="12">Author: David In't Veld (<Hyperlink NavigateUri="https://sites.google.com/view/david-veld" RequestNavigate="Hyperlink_RequestNavigate">Website</Hyperlink>)</TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Image Grid.Row="2" 
                   Source="pack://siteoforigin:,,,/Resources/DVLogo256.jpg" 
                   Height="35" 
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Bottom" 
                   Opacity="0.5"/>
        </Grid>
    </Grid>
</Window>