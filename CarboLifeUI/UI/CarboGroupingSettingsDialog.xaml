<Window x:Class="CarboLifeUI.UI.CarboGroupingSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Carbo Life Calculator: Revit Import Settings"
        Width="880" Height="680" MinWidth="880" MinHeight="680"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Icon="pack://application:,,,/CarboLifeUI;component/Resources/ico_clcwindow.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MyStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SectionBorder" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="12,8,12,12"/>
                <Setter Property="Margin" Value="0,0,0,0"/>
            </Style>

            <Style x:Key="HintText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="Gray"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,2,0,6"/>
            </Style>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <Style x:Key="CheckSection" TargetType="CheckBox" BasedOn="{StaticResource baseStyleBold}">
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="10">

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Name="btn_ExportSettings" Width="80" Height="26" Margin="0,0,6,0"
                            Style="{StaticResource ButtonStyle}" Click="btn_ExportSettings_Click">Export</Button>
                    <Button Name="btn_ImportSettings" Width="80" Height="26"
                            Style="{StaticResource ButtonStyle}" Click="btn_ImportSettings_Click">Import</Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Name="btn_ImportClose" Width="100" Height="26" Margin="0,0,8,0"
                            Style="{StaticResource ButtonStyle}" Click="Btn_ImportClose_Click">Ok &amp; Import</Button>
                    <Button Name="btn_Cancel" Width="80" Height="26"
                            Style="{StaticResource ButtonStyle}" Click="Btn_Cancel_Click">Cancel</Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main columns -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Basic Settings ═══ -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <Label Style="{StaticResource baseStyleTitle}" Content="Basic Element Import Settings" Margin="0,0,0,8"/>

                    <!-- Update Project -->
                    <TextBlock Style="{StaticResource FieldLabel}">Update project</TextBlock>
                    <TextBlock Style="{StaticResource HintText}">Select an existing project if you want to update it</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txt_ProjectPath" Grid.Column="0" Height="26"
                                 Style="{StaticResource textboxReadOnlyStyle}" IsEnabled="False"/>
                        <Button Name="btn_ProjectPath" Grid.Column="1" Margin="4,0,0,0"
                                Height="26" Style="{StaticResource ButtonStyle}"
                                Click="btn_ProjectPath_Click">…</Button>
                    </Grid>

                    <!-- Template -->
                    <TextBlock Style="{StaticResource FieldLabel}">Template</TextBlock>
                    <TextBlock Style="{StaticResource HintText}">Select the material template to use for this project</TextBlock>
                    <ComboBox Name="cbb_Template" Height="26" Margin="0,0,0,12"
                              Style="{StaticResource ComboBoxFlatStyle}"/>
                    <CheckBox Name="chk_UseAsDefault" Style="{StaticResource CheckSection}">
                        Make this the default template
                    </CheckBox>
                        <!-- Category -->
                    <TextBlock Style="{StaticResource FieldLabel}">Category</TextBlock>
                    <TextBlock Style="{StaticResource HintText}">The main grouping value. Defaults to the Revit Category Name; override with a custom parameter.</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cbb_MainGroup" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                  Style="{StaticResource ComboBoxFlatStyle}"
                                  DropDownClosed="cbb_MainGroup_DropDownClosed"/>
                        <TextBox Name="txt_CategoryparamName" Grid.Column="1" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                    </Grid>

                    <!-- Uncertainty Factor -->
                    <TextBlock Style="{StaticResource FieldLabel}">Uncertainty factor</TextBlock>
                    <TextBlock Style="{StaticResource HintText}">RICS guideline: 15% early stage · 10% design stage · 1% construction</TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBox Name="txt_UncertFact" Width="100" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                        <Label Content="%" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Map Reinforcement -->
                    <CheckBox Name="chk_MapReinforcement" Style="{StaticResource CheckSection}">
                        Map reinforcement quantities on import
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">
                        Auto-create reinforcement quantities based on material and category
                    </TextBlock>
                    <Button x:Name="btn_ReinforcementImport" HorizontalAlignment="Left"
                            Width="80" Height="26" Margin="0,0,0,12"
                            Style="{StaticResource ButtonStyle}"
                            Click="btn_ReinforcementImport_Click">Settings</Button>

                    <!-- Disabled items -->
                    <CheckBox Name="chk_AddSteelConnecitons" IsEnabled="False" Foreground="Gray"
                              Style="{StaticResource CheckSection}" Margin="0,0,0,6">
                        Add steel connection allowances on import
                    </CheckBox>
                    <CheckBox Name="chk_AddTimberConnections" IsEnabled="False" Foreground="Gray"
                              Style="{StaticResource CheckSection}">
                        Add timber connection allowances on import
                    </CheckBox>
                </StackPanel>
            </Border>

            <!-- ═══ RIGHT: Advanced Settings ═══ -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <Label Style="{StaticResource baseStyleTitle}" Content="Advanced Element Import Settings" Margin="0,0,0,8"/>

                    <!-- Substructure -->
                    <CheckBox x:Name="chk_ImportSubstructure" Style="{StaticResource CheckSection}">
                        Group by substructure parameter
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">Define a parameter to identify the building's substructure</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cbb_SubstructureImportType" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                  Style="{StaticResource ComboBoxFlatStyle}"/>
                        <TextBox Name="txt_SubstructureParamName" Grid.Column="1" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                    </Grid>

                    <!-- Material Grade -->
                    <CheckBox Name="chk_MaterialGrade" Style="{StaticResource CheckSection}">
                        Group by material grade
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">Define a parameter to import material grade</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cbb_GradeImportType" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                  Style="{StaticResource ComboBoxFlatStyle}"/>
                        <TextBox Name="txt_GradeImportValue" Grid.Column="1" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                    </Grid>

                    <!-- Correction Parameter -->
                    <CheckBox Name="chk_doCorrection" Style="{StaticResource CheckSection}">
                        Group by correction parameter
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">Define a parameter for material volume corrections</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cbb_CorrectionImportType" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                  Style="{StaticResource ComboBoxFlatStyle}"/>
                        <TextBox Name="txt_CorrectionImportValue" Grid.Column="1" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                    </Grid>

                    <!-- Existing Elements -->
                    <CheckBox Name="chk_ImportExisting" Style="{StaticResource CheckSection}">
                        Include &amp; group existing elements
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">Define the name of the "existing" phase below</TextBlock>
                    <TextBox Name="txt_ExistingPhaseName" Height="26" Margin="0,0,0,12"
                             Style="{StaticResource flatTextBox}"/>

                    <!-- Demolished Elements -->
                    <CheckBox Name="chk_ImportDemolished" Style="{StaticResource CheckSection}" Margin="0,0,0,12">
                        Include &amp; group demolished elements
                    </CheckBox>

                    <!-- Additional Parameter -->
                    <CheckBox Name="chk_AdditionalImport" Style="{StaticResource CheckSection}">
                        Group by additional parameter
                    </CheckBox>
                    <TextBlock Style="{StaticResource HintText}">Define an additional parameter to group the import</TextBlock>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Name="cbb_ExtraImportType" Grid.Column="0" Height="26" Margin="0,0,6,0"
                                  Style="{StaticResource ComboBoxFlatStyle}"/>
                        <TextBox Name="txt_ExtraImportValue" Grid.Column="1" Height="26"
                                 Style="{StaticResource flatTextBox}"/>
                    </Grid>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Use Previously Mapped Materials -->
                    <CheckBox Name="chk_UseMappedMaterialData" IsChecked="True"
                              Style="{StaticResource CheckSection}">
                        Use previously mapped materials
                    </CheckBox>

                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>