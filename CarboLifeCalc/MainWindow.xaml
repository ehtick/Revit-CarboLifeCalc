<Window x:Class="CarboLifeCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarboLifeCalc"
        mc:Ignorable="d"
        Title="Carbon Life Calculator" 
        Height="450" Width="800" 
        MinHeight="450" MinWidth="800" 
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing" ResizeMode="CanMinimize">

    <Window.Resources>
        <ResourceDictionary Source="MyStyles.xaml"/>
    </Window.Resources>

    <Grid Background="#F9F9F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="20,30,20,20">
                <TextBlock Text="ACTIONS" 
           FontSize="11" 
           FontWeight="Bold" 
           Foreground="Gray" 
           Margin="10,0,0,15" 
           />
                <Button Name="btn_Launch" Content="Launch New" Margin="0,5" Height="40" Style="{StaticResource ButtonStyle}" Click="btn_Launch_Click"/>
                <Button Name="btn_Open" Content="Open Project..." Margin="0,5" Height="40" Style="{StaticResource ButtonStyle}" Click="btn_Open_Click"/>
                <Button Name="btn_Materials" Content="Material Templates" Margin="0,5" Height="40" Style="{StaticResource ButtonStyle}" Click="btn_Materials_Click"/>
                <Button Name="btn_Addin" Content="Revit Add-in" Margin="0,5" Height="40" Style="{StaticResource ButtonStyle}" Click="Addin_Click"/>

                <Separator Margin="0,20" Background="#F0F0F0"/>

                <Button Name="btn_Test" Content="Run Test" Visibility="Collapsed" Height="35" Style="{StaticResource ButtonStyle}" Click="btn_Test_Click" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top">
                <Border CornerRadius="8" Background="White" Padding="10" BorderBrush="#EEE" BorderThickness="1">
                    <Image Source="pack://siteoforigin:,,,/Resources/Logo128.jpg" Width="80" Height="80" Stretch="Uniform"/>
                </Border>

                <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="Carbo Life Calculator" FontSize="28" FontWeight="Light" Foreground="#FFB21616"/>
                    <TextBlock Text="Embodied Carbon Calculator to EN 15978:2011" FontSize="14" Foreground="#666" Margin="2,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,30,0,0">
                <TextBlock Margin="0,5">
                    <Hyperlink NavigateUri="https://github.com/DavidVeld/CarboLifeCalc" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#007ACC" TextDecorations="None">
                        GitHub Project &amp; Documentation
                    </Hyperlink>
                </TextBlock>
                <TextBlock Name="lbl_Version" Text="Build: V X.X.X" FontSize="13" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                    <TextBlock Text="Author: David In't Veld" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,2">
                        <Hyperlink NavigateUri="https://sites.google.com/view/david-veld" RequestNavigate="Hyperlink_RequestNavigate" Foreground="Gray">
                            Visit Website
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <Image Grid.Column="1" Source="pack://siteoforigin:,,,/Resources/DVLogo256.jpg" Height="40" Opacity="0.7" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Grid>
</Window>