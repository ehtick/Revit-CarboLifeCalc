<Window x:Class="CarboLifeRevit.HeatMapCreator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" Name="HeatMapCreatorWin" 
        Title="Heatmapper | Carbon Footprint Visualizer"
        Height="850" Width="800" MinWidth="800" MinHeight="850"
        Loaded="Window_Loaded" Background="#F4F4F4" SizeChanged="Window_SizeChanged" 
        Icon="pack://application:,,,/CarboLifeRevit;component/UI/ico_clcwindow.ico">

    <Window.Resources>
        <ResourceDictionary Source="MyStyles.xaml"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Carbon Footprint Visualizer" FontSize="24" FontWeight="ExtraLight" Foreground="#B21616" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="Current Project Info" Margin="0,0,0,15" Style="{StaticResource bigStyle}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Project Name: " FontWeight="SemiBold" Width="150"/>
                        <TextBlock Name="lbl_name" Text="VALUE" Foreground="#555"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Total Embodied Carbon: " FontWeight="SemiBold" Width="150"/>
                        <TextBlock Name="lbl_total" Text="VALUE" Foreground="#B21616" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Name="lbl_debug" Text="Status: Idle" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="btn_Open" Content="Load Project..." Width="100" Height="30" Margin="5" Style="{StaticResource ButtonStyle}" Click="btn_Open_Click"/>
                    <Button Name="btn_Edit" Content="Edit Project..." Width="100" Height="30" Margin="5" Style="{StaticResource ButtonStyle}" Click="btn_Edit_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0,1,0,0">
            <TabItem Header="Colour Mapping" Padding="10,5">
                <Grid Background="White" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="HEATMAP TYPE" FontSize="10" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>
                            <RadioButton Name="rad_ByDensitykg" Content="By Material [kgCO₂/kg]" Margin="0,4" IsChecked="True" Click="rad_Control_Click" />
                            <RadioButton Name="rad_ByDensitym" Content="By Material [kgCO₂/m³]" Margin="0,4" Click="rad_Control_Click" />
                            <RadioButton Name="rad_ByGroup" Content="By Group [kgCO₂]" Margin="0,4" Click="rad_Control_Click" />
                            <RadioButton Name="rad_ByElement" Content="By Element [kgCO₂]" Margin="0,4" Click="rad_Control_Click"/>
                            <RadioButton Name="rad_MaterialTotals" Content="By Material Totals" Margin="0,4" Click="rad_Control_Click"/>
                            <Button x:Name="btn_Update" Content="Refresh Mapping" Margin="0,15,0,0" Height="30" Style="{StaticResource ButtonStyle}" Click="btn_Update_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="FILTERS &amp; APPEARANCE" FontSize="10" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,10"/>

                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cutoff Max" VerticalAlignment="Center"/>
                                <TextBox Name="txt_CutoffMax" Grid.Column="1" Text="9999" Style="{StaticResource flatTextBox}" IsEnabled="False"/>
                                <Slider Name="sld_Max" Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Maximum="1" Value="1" ValueChanged="sld_Max_ValueChanged"/>
                            </Grid>

                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cutoff Min" VerticalAlignment="Center"/>
                                <TextBox Name="txt_CutoffMin" Grid.Column="1" Text="0" Style="{StaticResource flatTextBox}" IsEnabled="False"/>
                                <Slider Name="sld_Min" Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Maximum="1" ValueChanged="sld_Min_ValueChanged"/>
                            </Grid>

                            <TextBlock Text="Out of Scope Style" Margin="0,10,0,2" FontSize="11" Foreground="#777"/>
                            <ComboBox x:Name="cbb_outofBounds" Height="26" Style="{StaticResource ComboBoxFlatStyle}"/>

                            <TextBlock Text="Colour Preset" Margin="0,10,0,2" FontSize="11" Foreground="#777"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="cbb_colours" Height="26" Style="{StaticResource ComboBoxFlatStyle}" DropDownClosed="cbb_colours_DropDownClosed"/>
                                <Button Name="btn_SaveColours" Grid.Column="1" Content="Save" Margin="5,0,0,0" Style="{StaticResource ButtonStyle}" Click="btn_SaveColours_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="15,0" BorderBrush="#EEE" BorderThickness="1" Background="#FAFAFA">
                        <Canvas Name="cnv_Graph" />
                    </Border>

                    <Grid Grid.Row="2" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <CheckBox Name="chk_Legend" Content="Create / Update Legend" IsChecked="True" VerticalAlignment="Center"/>
                            <TextBox Name="txt_LegendName" Width="180" Margin="0,5,0,0" Style="{StaticResource flatTextBox}" TextChanged="txt_LegendName_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Name="btn_MinOut" Content="Out" Width="35" Height="30" Background="CornflowerBlue" Click="btn_MinOut_Click" Foreground="White" BorderThickness="0"/>
                            <Button Name="btn_Low" Content="Low" Width="50" Height="30" Background="Lime" Click="btn_Low_Click" BorderThickness="0"/>
                            <Button Name="btn_Mid" Content="Mid" Width="50" Height="30" Background="Orange" Click="btn_Mid_Click" BorderThickness="0"/>
                            <Button Name="btn_High" Content="High" Width="50" Height="30" Background="Red" Click="btn_High_Click" BorderThickness="0"/>
                            <Button Name="btn_MaxOut" Content="Out" Width="35" Height="30" Background="Purple" Click="btn_MaxOut_Click" Foreground="White" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Button Name="btn_Apply" Content="Apply to Revit" Width="120" Height="30" Margin="0,0,0,5" Style="{StaticResource ButtonStyle}" Click="btn_Show_Click"/>
                            <Button Name="btn_Clear" Content="Clear View" Width="120" Height="25" Click="Btn_Clear_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Revit Parameter Sync" Padding="10,5">
                <StackPanel Margin="20" Background="White">
                    <TextBlock Text="PARAMETER SYNCHRONIZATION" FontSize="10" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,15"/>

                    <Border Background="#FFF9E7" BorderBrush="#FFE082" BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,0,0,20">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#856404">
                            The total embodied carbon will be written to the selected parameter. 
                            Note: The parameter must be a 'Number' type and an 'Instance' parameter in Revit.
                        </TextBlock>
                    </Border>

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Target Parameter:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Name="txt_Parameter" Grid.Column="1" Height="28" Style="{StaticResource flatTextBox}" TextChanged="txt_Parameter_TextChanged"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Name="btn_Importvalues" Content="Sync Values" Width="100" Height="28" Style="{StaticResource ButtonStyle}" Click="btn_Importvalues_Click"/>
                            <Button Name="btn_ClearValues" Content="Clear" Width="60" Height="28" Margin="5,0,0,0" Click="btn_ClearValues_Click"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="DASHBOARD VIEWS" FontSize="10" FontWeight="Bold" Foreground="Gray" Margin="0,10,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="New View Name:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Name="txt_DashBoardName" Grid.Column="1" Height="28" Style="{StaticResource flatTextBox}" TextChanged="txt_DashBoardName_TextChanged"/>
                        <Button Name="btn_createDashBoard" Grid.Column="2" Content="Create View" Width="100" Height="28" Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Click="btn_createDashBoard_Click"/>
                    </Grid>
                    <CheckBox Name="chk_Detailed" Content="Export Detailed Calculation Breakdown" Margin="115,10,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="0,15,0,0">
            <Button Name="btn_Ok" Content="Close Heatmapper" HorizontalAlignment="Right" Width="140" Height="32" Style="{StaticResource ButtonStyle}" Click="Btn_Ok_Click"/>
        </Border>
    </Grid>
</Window>